<?xml version="1.0" encoding="UTF-8"?>
<server description="Open Liberty Server with Admin Center">

    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>mpHealth-4.0</feature>
        <!-- 1. Enable the Admin Center web console -->
        <feature>adminCenter-1.0</feature>
    </featureManager>

    <!-- 2. Configure administrative security roles & users -->
    <quickStartSecurity userName="admin" userPassword="AdminPassword123" />

    <!-- 3. Secure keystore configuration (required for Admin Center HTTPS) -->
    <keyStore id="defaultKeyStore" password="KeystorePassword123" />

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="9080"
                  httpsPort="9443" />

    <webContainer deferServletLoad="false"/>
    <remoteFileAccess>
        <writeDir>${server.config.dir}</writeDir>
    </remoteFileAccess>
</server>