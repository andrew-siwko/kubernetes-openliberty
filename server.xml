<?xml version="1.0" encoding="UTF-8"?>
<server description="Empty Open Liberty Server">

    <!-- Enable the basic web engine and health reporting features -->
    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>mpHealth-4.0</feature>
    </featureManager>

    <!-- Listen on all interfaces so Kubernetes can access it -->
    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="9080"
                  httpsPort="9443" />

    <!-- Enable the default welcome landing page -->
    <webContainer deferServletLoad="false"/>

</server>
